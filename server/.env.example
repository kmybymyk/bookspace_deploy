# Supabase project
SUPABASE_PROJECT_REF=<replace-with-project-ref>
SUPABASE_URL=https://<replace-with-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<replace-with-service-role-key>

# PortOne billing
PORTONE_API_SECRET=<replace-with-portone-api-secret>
PORTONE_WEBHOOK_SECRET_PRIMARY=<replace-with-portone-webhook-secret>
PORTONE_WEBHOOK_SECRET_SECONDARY=<optional-second-secret-for-rotation>
PORTONE_WEBHOOK_TOLERANCE_SECONDS=300
PORTONE_STORE_ID=<replace-with-store-id>
PORTONE_CHANNEL_KEY_TOSSPAYMENTS=<replace-with-channel-key>
PORTONE_CHANNEL_KEY_PAYPAL_RT=<replace-with-channel-key>

# Legacy Stripe mock (local QA compatibility only)
STRIPE_WEBHOOK_SIGNING_SECRET=<optional-replace-with-whsec>

# Local API host/port (planned runtime server)
SUBSCRIPTION_API_HOST=127.0.0.1
SUBSCRIPTION_API_PORT=8787
SUBSCRIPTION_API_OPERATOR_TOKEN=<required-random-operator-token-for-manual-sync-endpoint>
SUBSCRIPTION_API_ALLOW_LOOPBACK_OPERATOR_ACCESS=0
SUBSCRIPTION_API_ENABLE_DEV_AUTH_STUB=1
SUBSCRIPTION_API_ENABLE_PLAN_OVERRIDE_ENDPOINT=1
SUBSCRIPTION_API_SESSION_TTL_SECONDS=3600
SUBSCRIPTION_API_SESSION_SLIDING_RENEW=1
SUBSCRIPTION_API_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SUBSCRIPTION_API_HEALTHZ_VERBOSE=1
SUBSCRIPTION_API_RATE_LIMIT_WINDOW_MS=60000
SUBSCRIPTION_API_RATE_LIMIT_DEFAULT_MAX_REQUESTS=180
SUBSCRIPTION_API_RATE_LIMIT_AUTH_MAX_REQUESTS=30
SUBSCRIPTION_API_RATE_LIMIT_AI_MAX_REQUESTS=60
SUBSCRIPTION_API_RATE_LIMIT_WEBHOOK_MAX_REQUESTS=120
SUBSCRIPTION_API_RATE_LIMIT_SYNC_MAX_REQUESTS=20
SUBSCRIPTION_API_RATE_LIMIT_MAX_KEYS=20000
SUBSCRIPTION_API_RATE_LIMIT_CLEANUP_INTERVAL_MS=30000
SUBSCRIPTION_API_TRUST_PROXY_FORWARDED_FOR=0

# Renderer HTTP mode
VITE_AUTH_API_MODE=http
VITE_SUBSCRIPTION_API_MODE=http
VITE_COPILOT_API_MODE=http
VITE_AUTH_API_BASE_URL=http://127.0.0.1:8787
VITE_SUBSCRIPTION_API_BASE_URL=http://127.0.0.1:8787
VITE_COPILOT_API_BASE_URL=http://127.0.0.1:8787

# Local mock hardening token (required by scripts/mock-subscription-api.mjs)
VITE_SUBSCRIPTION_MOCK_AUTH_TOKEN=<replace-with-mock-token>

# AI Copilot provider (optional, falls back to stub if missing)
AI_PROVIDER=groq
AI_MODEL=openai/gpt-oss-120b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=<replace-with-groq-api-key>
