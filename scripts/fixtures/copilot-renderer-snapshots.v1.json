{
  "version": "1.0.0",
  "capabilities": [
    { "id": "inline-bold", "needle": "\\*\\*([^*]+)\\*\\*" },
    { "id": "inline-italic-star", "needle": "\\*([^*\\n]+)\\*" },
    { "id": "inline-italic-underscore", "needle": "_([^_\\n]+)_" },
    { "id": "inline-code", "needle": "`([^`]+)`" },
    { "id": "inline-link", "needle": "href={match[3]}" },
    { "id": "inline-strikethrough", "needle": "~~([^~]+)~~" },
    { "id": "heading", "needle": "const isHeading = (line: string)" },
    { "id": "unordered", "needle": "const isUnordered = (line: string)" },
    { "id": "ordered", "needle": "const isOrdered = (line: string)" },
    { "id": "checklist", "needle": "const checklistMatch = raw.match(/^\\s*[-*]\\s+\\[(x|X| )\\]\\s+(.*)$/)" },
    { "id": "blockquote", "needle": "const isQuote = (line: string)" },
    { "id": "fenced-code", "needle": "const isFence = (line: string)" },
    { "id": "horizontal-rule", "needle": "const isHr = (line: string)" },
    { "id": "table", "needle": "const isTableLine = (line: string)" }
  ]
}
